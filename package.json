{
	"name": "svelai",
	"version": "0.0.8",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.3.1",
		"@eslint/js": "^9.32.0",
		"@playwright/test": "^1.54.1",
		"@sveltejs/adapter-auto": "^6.0.1",
		"@sveltejs/kit": "^2.26.1",
		"@sveltejs/package": "^2.4.0",
		"@sveltejs/vite-plugin-svelte": "^6.1.0",
		"@tailwindcss/vite": "^4.1.11",
		"@testing-library/jest-dom": "^6.6.4",
		"@testing-library/svelte": "^5.2.8",
		"eslint": "^9.32.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.11.0",
		"globals": "^16.3.0",
		"jsdom": "^26.1.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"publint": "^0.3.12",
		"svelte": "^5.37.1",
		"svelte-check": "^4.3.0",
		"tailwindcss": "^4.1.11",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.38.0",
		"vite": "^7.0.6",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"svelte"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.3",
		"bits-ui": "^2.9.0",
		"color2k": "^2.0.3",
		"colorizr": "^3.0.8",
		"cva": "1.0.0-beta.3",
		"melt": "^0.38.0",
		"runed": "^0.31.1",
		"tailwind-merge": "^3.3.1",
		"type-fest": "^4.41.0",
		"valibot": "^1.1.0"
	},
	"exports": {
		"./package.json": "./package.json",
		"./": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./Form": {
			"types": "./dist/components/Form/Form/Form.svelte.d.ts",
			"svelte": "./dist/components/Form/Form/Form.svelte",
			"default": "./dist/components/Form/Form/Form.svelte"
		},
		"./tailwind-plugin": {
			"types": "./dist/tailwind/index.d.ts",
			"default": "./dist/tailwind/index.js"
		},
		"./tailwind-theme": {
			"types": "./dist/tailwind/theme.d.ts",
			"default": "./dist/tailwind/theme.js"
		},
		"./MultiStepForm": {
			"types": "./dist/components/Form/MultiStepForm/MultiStepForm.svelte.d.ts",
			"svelte": "./dist/components/Form/MultiStepForm/MultiStepForm.svelte",
			"default": "./dist/components/Form/MultiStepForm/MultiStepForm.svelte"
		},
		"./TextArea": {
			"types": "./dist/components/Form/TextArea/TextArea.svelte.d.ts",
			"svelte": "./dist/components/Form/TextArea/TextArea.svelte",
			"default": "./dist/components/Form/TextArea/TextArea.svelte"
		}
	},
	"typesVersion": {
		"*": {
			"./Form": [
				"./dist/components/Form/Form/Form.svelte.d.ts"
			],
			"./tailwind-plugin": [
				"./dist/tailwind/index.d.ts"
			],
			"./tailwind-theme": [
				"./dist/tailwind/theme.d.ts"
			],
			"./MultiStepForm": [
				"./dist/components/Form/MultiStepForm/MultiStepForm.svelte.d.ts"
			],
			"./TextArea": [
				"./dist/components/Form/TextArea/TextArea.svelte.d.ts"
			]
		}
	}
}
